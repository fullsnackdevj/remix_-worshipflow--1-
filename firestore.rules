rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Chat channels ──────────────────────────────────────────────────────────
    // Allow authenticated users to read messages directly via onSnapshot.
    // All writes (send, edit, delete, pin, react) go through the server
    // Admin SDK which bypasses these rules entirely.
    match /chat_channels/{channelId}/messages/{msgId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Events module ──────────────────────────────────────────────────────────
    // Admin creates events (client-side), public reads for registration page.
    match /events/{eventId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    // Registrants: public create (no login needed), auth'd read & update (admin).
    // allow list (query) without auth so the public registration page can do
    // the duplicate-phone check via getDocs + where("phone", "==", ...)
    match /events/{eventId}/registrants/{registrantId} {
      allow get:    if request.auth != null;   // individual doc — admin only
      allow list:   if true;                   // query — needed by public dup-check
      allow create: if true;
      allow update: if request.auth != null;
    }
    // Contributions (internal events):
    // - read:   true — collector & member form need to read
    // - create: true — members self-register via public form link (no login required)
    // - update: true — collector marks paid/unpaid via the secure collector link
    // - delete: auth only — admin only
    match /events/{eventId}/contributions/{memberId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // ── Bible module — user-owned data ────────────────────────────────────────
    // My Verses (single aggregated doc per user)
    match /users/{userId}/bibleCollection/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // My Devotions (one doc per devotion entry)
    match /users/{userId}/bibleDevotions/{devotionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // My Playlists (one doc per playlist — full Firestore sync)
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Shared Playlists — public read, auth'd write (via server only) ─────────
    // Anyone with the slug link can read the playlist data.
    // All writes go through the Netlify Admin SDK — client write is denied.
    match /sharedPlaylists/{slug} {
      allow read:  if true;
      allow write: if false;
    }

    // ── All other collections ──────────────────────────────────────────────────
    // All other reads/writes go through Netlify serverless functions
    // (server-side Admin SDK) — deny direct client access.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
